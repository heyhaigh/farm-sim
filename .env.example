# Propagate — copy to .env (gitignored) and fill in. All optional: with none set,
# the game runs on the embedded offline crew + procedural text.

# --- Memory corpus: a self-hosted SuperMemory instance -----------------------
# https://github.com/supermemoryai/supermemory  ->  `npx supermemory local`
SUPERMEMORY_URL=http://localhost:6767
SUPERMEMORY_API_KEY=sm_your_key_here          # printed on the instance's first boot

# --- Expressive LLM channels (chat / DM / conscience) ------------------------
# Any OpenAI-compatible endpoint. Leave OPENAI_BASE_URL unset to use OpenAI;
# point it at a local server (e.g. Ollama) for a fully self-contained stack.
OPENAI_API_KEY=sk-your_key_here               # blank is fine for most local servers
# OPENAI_BASE_URL=http://localhost:11434/v1   # e.g. Ollama
# RY_FARMS_LLM_MODEL=gpt-4.1-mini             # or a local model id (e.g. gpt-oss:20b)
